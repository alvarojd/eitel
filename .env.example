# ==============================================================================
# CONFIGURACIÓN DEL ENTORNO LOCAL - HEXASENSE IOT DASHBOARD V2
# ==============================================================================
# Copia este archivo como '.env.local' y reemplaza los valores de ejemplo 
# con las credenciales correspondientes a tu infraestructura.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. BASE DE DATOS (POSTGRESQL) - REQUERIDO
# ------------------------------------------------------------------------------
# Cadena de conexión principal. Si usas Vercel/Supabase, esto es provisto por ellos.
POSTGRES_URL="postgres://usuario:contraseña@host:6543/nombre_db?sslmode=require"

# (Opcional) Usada por Drizzle ORM si POSTGRES_URL no está disponible.
# DATABASE_URL="postgres://..."

# ------------------------------------------------------------------------------
# 2. SEGURIDAD Y AUTENTICACIÓN - REQUERIDO
# ------------------------------------------------------------------------------
# Secreto para la firma y validación de JSON Web Tokens (Enterprise Security).
# Genera uno seguro usando: openssl rand -base64 32
JWT_SECRET="tu-super-secreto-para-jwt-reemplazar-en-produccion"

# ------------------------------------------------------------------------------
# 3. CONFIGURACIÓN DE APLICACIÓN - REQUERIDO
# ------------------------------------------------------------------------------
# URL base del dashboard. Se utiliza para redirecciones, webhooks locales y enlaces.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# 4. INTEGRACIÓN IOT (THE THINGS NETWORK) - REQUERIDO PARA INGESTA
# ------------------------------------------------------------------------------
# Secreto de seguridad para validar la autenticidad de los datos provenientes 
# del Webhook configurado en TTN (The Things Network).
TTN_WEBHOOK_SECRET="clave-privada-validar-datos-ttn"

# ------------------------------------------------------------------------------
# 5. SERVICIO DE CORREO ELECTRÓNICO (SMTP) - RECOMENDADO PARA ALERTAS
# ------------------------------------------------------------------------------
# Credenciales para el envío de alertas automatizadas (p. ej. niveles críticos).
SMTP_USER="alertas@tudominio.com"
SMTP_PASS="contraseña-de-aplicacion-smtp"
SMTP_FROM_EMAIL="\"Alertas Hexasense\" <alertas@tudominio.com>"

# ------------------------------------------------------------------------------
# 6. TAREAS PROGRAMADAS (CRON JOBS) - REQUERIDO PARA TAREAS EN SEGUNDO PLANO
# ------------------------------------------------------------------------------
# Si despliegas en Vercel, ellos inyectan esta variable automáticamente. 
# En entornos autohospedados, debes configurarla para proteger las rutas /api/cron/*
CRON_SECRET="secreto-para-proteger-ejecucion-de-crons"
